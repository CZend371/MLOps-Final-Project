# Copy this file to .env and fill in your actual values.
# The .env file is git-ignored and should never be committed.

# S3 bucket where model.pkl and predictions/ are stored
S3_BUCKET_NAME=<your-s3-bucket-name>

# SQS queue URL for inference job messages
SQS_QUEUE_URL=<your-sqs-queue-url>

# AWS region (default: us-east-1)
AWS_DEFAULT_REGION=us-east-1

# S3 key for the trained model (default: model.pkl)
S3_MODEL_KEY=model.pkl

# Full ECR image URI used by the ECS task definition (substituted via envsubst)
# Format: <account-id>.dkr.ecr.<region>.amazonaws.com/<repo-name>:latest
ECR_IMAGE_URI=<your-ecr-image-uri>
